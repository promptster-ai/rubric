{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://promptster.ai/schema/rubric.schema.json",
  "title": "Promptster AI-fluency rubric",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "phases",
    "tiers",
    "dimensions",
    "bands",
    "methodologySummary",
    "methodologyGroups"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "tiers": {
      "type": "array",
      "$comment": "Exactly the five tierKey values, each present once. maxItems + a contains per key forbids both omissions (a missing key fails its contains) and duplicates (a dupe leaves no room for the omitted key under maxItems).",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/tier" },
      "allOf": [
        { "contains": { "properties": { "key": { "const": "strong" } } } },
        { "contains": { "properties": { "key": { "const": "adequate" } } } },
        { "contains": { "properties": { "key": { "const": "developing" } } } },
        { "contains": { "properties": { "key": { "const": "insufficient_evidence" } } } },
        { "contains": { "properties": { "key": { "const": "not_collectible" } } } }
      ]
    },
    "dimensions": {
      "type": "array",
      "$comment": "Open set — the dimension list is community-extensible. Structural checks only; each item must be a well-formed dimension. Key uniqueness is enforced at runtime by index.ts.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimension" }
    },
    "bands": {
      "type": "array",
      "$comment": "Exactly the three outcome-band keys, each present once. Closed set (unlike dimensions): same maxItems + per-key contains pattern the tiers array uses, forbidding both omissions and duplicates.",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/band" },
      "allOf": [
        { "contains": { "properties": { "key": { "const": "craft" } } } },
        { "contains": { "properties": { "key": { "const": "durability" } } } },
        { "contains": { "properties": { "key": { "const": "cost" } } } }
      ]
    },
    "methodologySummary": { "type": "string", "minLength": 1 },
    "methodologyGroups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/methodologyGroup" }
    }
  },
  "$defs": {
    "phaseKey": {
      "type": "string",
      "enum": ["discovery", "implementation", "verification", "cross_cutting"]
    },
    "tierKey": {
      "type": "string",
      "enum": [
        "strong",
        "adequate",
        "developing",
        "insufficient_evidence",
        "not_collectible"
      ]
    },
    "surface": {
      "type": "string",
      "enum": ["hiring", "teams"]
    },
    "dimensionKey": {
      "type": "string",
      "$comment": "Open by design — any lower_snake_case key. The shipped keys are direction, verification, context, leverage.",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "bandKey": {
      "type": "string",
      "$comment": "Closed set — the three fixed outcome bands.",
      "enum": ["craft", "durability", "cost"]
    },
    "reliabilityTier": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "detail", "url"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "blurb"],
      "properties": {
        "key": { "$ref": "#/$defs/phaseKey" },
        "label": { "type": "string", "minLength": 1 },
        "blurb": { "type": "string", "minLength": 1 }
      }
    },
    "tier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "shortLabel",
        "intent",
        "hex",
        "text",
        "badge",
        "rank",
        "help",
        "structural"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/tierKey" },
        "label": { "type": "string", "minLength": 1 },
        "shortLabel": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "enum": ["good", "gap", "neutral"] },
        "hex": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "badge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["color", "background", "border"],
          "properties": {
            "color": { "type": "string", "minLength": 1 },
            "background": { "type": "string", "minLength": 1 },
            "border": { "type": "string", "minLength": 1 }
          }
        },
        "rank": { "type": "integer", "minimum": 0 },
        "help": { "type": "string", "minLength": 1 },
        "structural": { "type": "boolean" }
      }
    },
    "anchorSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["developing", "adequate", "strong"],
      "properties": {
        "developing": { "type": "string", "minLength": 1 },
        "adequate": { "type": "string", "minLength": 1 },
        "strong": { "type": "string", "minLength": 1 }
      }
    },
    "subFacet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "reliabilityTier", "signal", "anchors"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "reliabilityTier": { "$ref": "#/$defs/reliabilityTier" },
        "signal": { "type": "string", "minLength": 1 },
        "anchors": { "$ref": "#/$defs/anchorSet" },
        "beta": { "type": "boolean" },
        "scoring": { "type": "string", "enum": ["graded", "positive_only"] }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "phase",
        "surfaces",
        "reliabilityTier",
        "measures",
        "detail",
        "anchors",
        "subFacets",
        "sources"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/dimensionKey" },
        "label": { "type": "string", "minLength": 1 },
        "phase": { "$ref": "#/$defs/phaseKey" },
        "surfaces": {
          "type": "array",
          "$comment": "Product surfaces this dimension is judged on. A dimension absent from a surface is omitted from judging there entirely — different from not_collectible, which is a tool limit within a surface.",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/surface" }
        },
        "reliabilityTier": { "$ref": "#/$defs/reliabilityTier" },
        "measures": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "anchors": { "$ref": "#/$defs/anchorSet" },
        "subFacets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/subFacet" }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "band": {
      "type": "object",
      "additionalProperties": false,
      "$comment": "An outcome band — mirrors a dimension's descriptive fields minus the process-judging ones, plus the composite:false marker. Graded on the five tiers but reported apart from the composite process score.",
      "required": [
        "key",
        "label",
        "composite",
        "measures",
        "detail",
        "anchors",
        "sources"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/bandKey" },
        "label": { "type": "string", "minLength": 1 },
        "composite": {
          "const": false,
          "$comment": "Always false: bands are non-composite by definition and must never be weighted into the process score."
        },
        "measures": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "anchors": { "$ref": "#/$defs/anchorSet" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "methodologyGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "sources"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    }
  }
}
