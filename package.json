{
  "name": "@promptster/rubric",
  "version": "0.6.0",
  "description": "Promptster AI-fluency rubric — the public data artifact (4 process dimensions + sub-facets & behavioral anchors, 5 tiers, methodology sources). Anchors and citations only; criteria and scoring weights are not part of this package.",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./rubric.json": "./src/rubric.json",
    "./templates.json": "./src/templates.json",
    "./schema.json": "./src/rubric.schema.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/promptster-ai/rubric.git"
  },
  "homepage": "https://github.com/promptster-ai/rubric#readme",
  "bugs": {
    "url": "https://github.com/promptster-ai/rubric/issues"
  },
  "keywords": [
    "ai",
    "rubric",
    "evaluation",
    "coding-agents",
    "developer-productivity",
    "ai-fluency"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "npx -y tsx scripts/validate.mjs",
    "render": "node scripts/render-readme.mjs",
    "render:check": "node scripts/render-readme.mjs --check"
  }
}
